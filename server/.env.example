# Copy this file to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=4000

# Postgres connection string (use Neon's pooled "-pooler" URL in production)
DATABASE_URL="postgresql://user:password@localhost:5432/adel_finance"

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
ADMIN_JWT_SECRET="replace-with-a-different-long-random-secret"

# Frontend origins allowed to call this API (comma-free, exact origin, no trailing slash)
WEB_ORIGIN="http://localhost:5173"
ADMIN_ORIGIN="http://localhost:5174"

# Server-side only key for the AI transaction-parsing proxy (get one at console.anthropic.com)
ANTHROPIC_API_KEY=""

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# Used once by `npm run seed:admin` to create the first admin panel login
ADMIN_SEED_USERNAME="admin"
ADMIN_SEED_PASSWORD="change-me-before-seeding"
